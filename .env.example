# Copy this file to .env and fill in your values

# Required — generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# This key encrypts all secrets stored in the database (OAuth tokens, client secrets).
# Changing it after first run will make existing credentials unreadable — you'll need to reconnect.
APP_SECRET_KEY=

# SQLite database path inside the container. No need to change this for local dev.
DATABASE_URL=sqlite+aiosqlite:////app/data/app.db

# development | production
# Controls log output format. Use "production" when deploying to a server.
APP_ENV=development

# OAuth credentials and all other settings are configured through the Settings UI at runtime.
# Do not add LINEAR_CLIENT_ID, LINEAR_CLIENT_SECRET, SLACK_CLIENT_ID, or SLACK_CLIENT_SECRET here.
